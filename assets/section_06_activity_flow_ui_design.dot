    labelloc="t";
    fontsize=18;
    fontname="DejaVu Sans Bold";
    n0 [label="Palette", fillcolor="#fff3e8"]; n1 [label="Typography", fillcolor="#f3f4f6"]; n2 [label="Buttons", fillcolor="#f3f4f6"]; n3 [label="Hover Feedback", fillcolor="#f3f4f6"]; n4 [label="Screen Consistency", fillcolor="#f3f4f6"]; n5 [label="Branding", fillcolor="#fff3e8"];
    n0 -> n1; n1 -> n2; n2 -> n3; n3 -> n4; n4 -> n5;
